{
  "name": "zcvios-core-alpha",
  "version": "1.1.0-alpha",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "prisma:generate": "DATABASE_URL=file:./dev.db prisma generate",
    "prisma:migrate": "DATABASE_URL=file:./dev.db prisma migrate dev --name init_alpha",
    "prisma:push": "DATABASE_URL=file:./dev.db prisma db push",
    "preseed": "npm run prisma:generate",
    "seed": "DATABASE_URL=file:./dev.db node prisma/seed.mjs",
    "test": "/root/.venv/bin/python -m pytest -q tests/test_rpc_auth_guards.py tests/test_rpc_authenticated_flows.py tests/test_strategy_trigger_scope.py",
    "test:privacy": "/root/.venv/bin/python -m pytest -q tests/test_rpc_authenticated_flows.py -k export"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@libsql/client": "^0.17.0",
    "@prisma/adapter-libsql": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "bcryptjs": "^3.0.3",
    "date-fns": "^4.1.0",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.576.0",
    "next": "16.2.3",
    "next-auth": "^4.24.13",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-is": "^19.2.4",
    "recharts": "^3.7.0",
    "sonner": "^2.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "^7.4.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
