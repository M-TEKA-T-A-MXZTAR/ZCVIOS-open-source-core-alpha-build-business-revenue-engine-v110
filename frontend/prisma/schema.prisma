generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum BusinessType {
  service
  product
  digital
  hybrid
  unknown
}

enum Lever {
  Distribution
  Conversion
  Pricing
  Traffic
  Retention
  AssetBuild
  Automation
  Authority
}

enum LogCategory {
  LEVER
  ASSET_BUILD
  MAINTENANCE
  DRIFT
}

enum MissionSource {
  AI
  TEMPLATE
  RESET
}

enum GrowthStatus {
  below_target
  within_target
  above_target
}

enum ExecutionStatus {
  low
  moderate
  strong
}

enum DriftStatus {
  low
  moderate
  high
}

enum AllocationAdjustment {
  none
  tighten_focus
  increase_asset_build
}

model User {
  id                        String          @id @default(cuid())
  email                     String          @unique
  passwordHash              String?
  name                      String?
  googleId                  String?         @unique
  businessUrl               String?
  socialLinks               String?
  businessDescription       String?
  businessType              BusinessType    @default(unknown)
  hoursAvailablePerWeek     Int             @default(40)
  weeklyRevenueBaselineCents Int            @default(0)
  targetMonthlyIncomeCents  Int             @default(300000)
  targetMaxHoursPerWeek     Int             @default(35)
  consistencyWindowMonths   Int             @default(6)
  fullLoggingEnabled        Boolean         @default(false)
  commandMode               Boolean         @default(true)
  openAiApiKeyEncrypted     String?
  openAiKeyLast4            String?
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt

  weeklyRevenues WeeklyRevenue[]
  strategies     WeeklyStrategy[]
  logs           DailyLog[]
  missions       DailyMission[]
  pauses         PauseWindow[]
}

model WeeklyRevenue {
  id                String   @id @default(cuid())
  userId            String
  weekStart         DateTime
  revenueCents      Int
  note              String?
  strategyTriggered Boolean  @default(false)
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
  @@index([userId, weekStart])
}

model WeeklyStrategy {
  id                      String               @id @default(cuid())
  userId                  String
  weekStart               DateTime
  selectedLever           Lever
  reasoningSummary        String
  growthStatus            GrowthStatus
  executionStatus         ExecutionStatus
  driftStatus             DriftStatus
  leverChangeRecommended  Boolean
  allocationAdjustment    AllocationAdjustment
  manualOverride          Boolean              @default(false)
  overrideReason          String?
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
  @@index([userId, weekStart])
}

model DailyLog {
  id        String      @id @default(cuid())
  userId    String
  date      DateTime
  minutes   Int
  category  LogCategory
  completed Boolean     @default(true)
  note      String?
  createdAt DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

model DailyMission {
  id                 String        @id @default(cuid())
  userId             String
  date               DateTime
  lever              Lever
  primaryTask        String
  supportTask        String?
  doNotDoReminder    String
  recommendedMinutes Int
  startNowStep       String
  successDefinition  String
  source             MissionSource @default(TEMPLATE)
  createdAt          DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model PauseWindow {
  id        String   @id @default(cuid())
  userId    String
  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
}
